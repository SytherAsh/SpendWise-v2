# Copy to .env and fill in values locally. Never commit the real .env file.
# See docs/deployment.md — Environment Variables — Spring Boot Backend.

SUPABASE_URL=
SUPABASE_KEY=

# Not part of the docs/deployment.md list — SUPABASE_URL/KEY above are
# Supabase's client-SDK/REST credentials, not a raw JDBC connection. These
# three fill that gap for Flyway/Spring's DataSource. Safe to leave unset
# locally (defaults to the Dockerized Postgres in docker-compose.yml); set
# to the real Supabase Postgres connection string in dev/prod.
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Second role, same database, with BYPASSRLS (db-init/02-jobs-role.sql) — used
# only by @Scheduled job beans that must read across all users (E4-S3-T3/T4).
# Safe to leave unset locally (defaults to spendwise_jobs / the Dockerized
# Postgres). See docs/security.md "Cross-user reads for background jobs".
SPRING_DATASOURCE_JOBS_USERNAME=
SPRING_DATASOURCE_JOBS_PASSWORD=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FASTAPI_ML_URL=http://ml-service/
JWT_SECRET=
SENTRY_DSN=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
ADMIN_JWT_SECRET=
# Single seeded admin credential (E11-S1-T1) — ADMIN_PASSWORD_HASH is a bcrypt hash (not the
# raw password), checked with Spring Security's BCryptPasswordEncoder.
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
FCM_SERVER_KEY=
ML_INTERNAL_KEY=
ML_LOW_CONFIDENCE_THRESHOLD=0.5
# Background-job schedules (retrain, canonicalization, alert evaluation, etc.) are no longer env
# vars -- ADR-018 (2026-07-19) moved them into the admin-configurable job_schedules table, edited
# from the admin portal's "Scheduled Jobs" page at runtime.
