# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Shared build output (Gradle "build/"+"out/", npm/Python "dist/") —
# intentionally not scoped per-language since these dir names recur across
# backend/, android/, frontend/, and ml/.
build/
out/
dist/

# Java / Kotlin / Spring Boot
*.class
*.jar
!**/gradle/wrapper/gradle-wrapper.jar
*.war
target/
.gradle/

# Node / Next.js
node_modules/
.next/
.cache/
.vercel
*.tsbuildinfo
next-env.d.ts
npm-debug.log*
coverage/

# Python / FastAPI
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/

# ML training data (real personal bank statement data — never committed).
# knowledge_base/, scripts/, and docs under ml/labeling/ ARE committed —
# only the raw/working data under ml/labeling/datasets/ is excluded.
ml/data/*.xlsx
ml/data/*.csv
ml/labeling/datasets/

# Generated evaluation reports (E4-S2-T5) — timestamped output regenerated by
# every evaluate.py / GET /evaluate run, not source. ml/models/*.joblib is
# NOT excluded here — that artifact IS committed (docs/deployment.md "Model
# artifacts": no external model store at MVP).
ml/evaluation/reports/*.json

# Android
android/local.properties
android/app/release/
*.apk
*.aab

# Secrets
*.pem
*.key
firebase-adminsdk*.json
google-services.json
