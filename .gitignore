node_modules/
.next/
.cache/
.vercel
*.tsbuildinfo
next-env.d.ts
npm-debug.log*
coverage/

# Python / FastAPI
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/

